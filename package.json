    "next-sanity": "^9.8.0",
    "sanity": "^3.50.0",
    "@sanity/image-url": "^1.1.0",
    "@sanity/vision": "^3.50.0",
    "@next/third-parties": "^15.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "eslint": "^9.0.0",
