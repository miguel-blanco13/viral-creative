# ─── VIRAL CREATIVE — variables de entorno (copia a .env.local) ───

# URL pública del sitio (sin barra final). Se usa en SEO, sitemap y OpenGraph.
NEXT_PUBLIC_SITE_URL=https://viralcreative.com

# WhatsApp (CTA principal) — número real con código de país, sin signos.
# Nota: si defines el número en el CMS (Ajustes del sitio), ese tiene prioridad.
NEXT_PUBLIC_WHATSAPP_NUMBER=573000000000

# ─── Sanity CMS ───
# projectId y dataset se ven en sanity.io/manage. Déjalos vacíos hasta crear
# el proyecto: el sitio funciona con contenido por defecto mientras tanto.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Token de solo lectura (Manage → API → Tokens → Viewer). Server-only.
SANITY_API_READ_TOKEN=

# Secreto compartido con el webhook de Sanity para revalidar el ISR.
# Debe coincidir con el "Secret" del webhook en Sanity Manage.
SANITY_REVALIDATE_SECRET=

# ─── Analítica (opcional — solo cargan tras aceptar cookies) ───
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Instagram feed (pendiente de implementar) ───
INSTAGRAM_ACCESS_TOKEN=
